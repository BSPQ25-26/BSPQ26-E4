# Copy this file to .env and fill in real values before running docker-compose.
#
#   cp .env.example .env
#   docker compose up --build

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — override the host ports if 3000 or 8080 are taken by another
# process on your machine. The container ports stay the same internally,
# only the host mapping changes.
# FRONTEND_PORT=3001
# BACKEND_PORT=8081
